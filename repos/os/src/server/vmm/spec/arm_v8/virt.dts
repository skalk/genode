	clk_enet1_root: clock-enet1-root {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <133000000>;
		clock-output-names = "clk_enet1_root";
	};

	clk_enet_timer: clock-enet-timer {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
		clock-output-names = "clk_enet_timer";
	};

	clk_enet_ref: clock-enet-ref {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
		clock-output-names = "clk_enet_ref";
	};

	clk_enet_phy_ref: clock-enet-phy-ref {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
		clock-output-names = "clk_enet_phy_ref";
	};

	fec1: ethernet@30be0000 {
		compatible = "fsl,imx8mq-fec", "fsl,imx6sx-fec";
		reg = <0x00 0x30be0000 0x00 0x10000>;
		interrupts = <0x00 118 0x04>,
		             <0x00 119 0x04>,
		             <0x00 120 0x04>;
		clocks = <&clk_enet1_root>,
		         <&clk_enet1_root>,
		         <&clk_enet_timer>,
		         <&clk_enet_ref>,
		         <&clk_enet_phy_ref>;
/*
		clocks = <&clk 182>,
		         <&clk 182>,
		         <&clk 138>,
		         <&clk 137>,
		         <&clk 139>;
*/
		clock-names = "ipg", "ahb", "ptp",
		              "enet_clk_ref", "enet_out";
		fsl,num-tx-queues = <3>;
		fsl,num-rx-queues = <3>;
		status = "okay";
		phy-mode = "rgmii-id";
		phy-handle = <&ethphy0>;
		fsl,magic-packet;

		mdio {
			#address-cells = <1>;
			#size-cells = <0>;
			
			ethphy0: ethernet-phy@0 {
				compatible = "ethernet-phy-ieee802.3-c22";
				reg = <0>;
			};
		};
	};
};
